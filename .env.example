# Example environment variables for local development
PORT=8080
HF_HOME=/opt/hf-cache
DAILY_RATE_LIMIT=50/day

# Default AI provider (default or puter_ai)
# Used when provider is not specified in the request body
DEFAULT_PROVIDER=puter_ai

# Disable local HF model downloads at runtime (use Puter AI only)
# Set to true in Cloud Run to avoid Hugging Face rate limits
DISABLE_LOCAL_MODEL=true

# Use either API_KEYS or API_KEY_HASHES. Leave one empty.
API_KEYS=dev-key
API_KEY_HASHES=

# Allowed origins for API key bypass (comma-separated)
# Frontend clients from these origins can access without X-API-Key header
# Leave empty to require API key for all requests
# Examples: http://localhost:3000,https://yourdomain.com,https://app.yourdomain.com
ALLOWED_ORIGINS=

# Puter AI provider settings (used when provider=puter_ai)
PUTER_API_KEY=
PUTER_MODEL=gpt-4o-mini
PUTER_DRIVER=openai-completion
PUTER_PROMPT_MAX_CHARS=6000