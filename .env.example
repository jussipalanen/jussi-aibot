# Example environment variables for local development
PORT=8080
HF_HOME=/opt/hf-cache
DAILY_RATE_LIMIT=50/day

# Default AI provider (default or puter_ai)
# Used when provider is not specified in the request body
DEFAULT_PROVIDER=puter_ai

# Disable local HF model downloads at runtime (use Puter AI only)
# Set to true in Cloud Run to avoid Hugging Face rate limits
DISABLE_LOCAL_MODEL=true

# Use either API_KEYS or API_KEY_HASHES. Leave one empty.
API_KEYS=
API_KEY_HASHES=

# Secret key for AI endpoints — server-to-server only, never in browser JS.
# Generate: openssl rand -hex 32
# Callers must send:  Authorization: Bearer <key>
# Leave empty in local dev (no auth required).
AI_SECRET_KEY=

# Allowed origins for AI endpoints (comma-separated).
# When set, only browser requests from these origins can reach /ai/chat and /ai/review.
# Leave empty in local dev (all origins allowed).
# In production, set to your known frontend domains to prevent unauthorised use.
# Examples: https://jussimatic.com,https://jussispace.com,http://localhost:3000
ALLOWED_ORIGINS=

# Puter AI provider settings (used when provider=puter_ai)
PUTER_API_KEY=
PUTER_MODEL=gpt-4o-mini
PUTER_DRIVER=openai-completion
PUTER_PROMPT_MAX_CHARS=6000

# Google Vertex AI settings (shared by resume review provider and JussiSpace agent)
GCP_PROJECT=your-gcp-project
GCP_LOCATION=europe-north1

# Vertex AI resume review provider settings (used when provider=vertex_ai)
VERTEX_MODEL=gemini-2.5-flash-lite

# Vertex AI model for the JussiSpace chat agent (needs reliable function calling)
AGENT_VERTEX_MODEL=gemini-2.5-flash-lite
AGENT_GCP_LOCATION=europe-north1

# Per-handler model overrides (optional — falls back to AGENT_VERTEX_MODEL)
JUSSISPACE_VERTEX_MODEL=gemini-2.5-flash-lite
JUSSIMATIC_CV_VERTEX_MODEL=gemini-2.5-flash-lite
VERTEX_PROMPT_MAX_CHARS=6000

# Jussimatic AI CV Chat settings
JUSSIMATIC_CV_API_URL=

# JussiSpace agent settings
JUSSISPACE_API_URL=https://backend-lab-jussispace.jussialanen.com/api
# Local dev note: if running inside Docker on WSL2, use host.docker.internal to reach
# services on the Windows host (localhost and WSL2 IPs won't work from inside a container).
# Example: JUSSISPACE_API_URL=http://host.docker.internal:3000/api
JUSSISPACE_FRONTEND_URL=https://jussispace-production.lab.jussialanen.com
AGENT_EMAIL=agent@jussispace.internal
AGENT_PASSWORD=your-agent-password

# Jussilog storage settings (for CV photos)
JUSSILOG_STORAGE_BASE_URL=https://jussilog-backend-uploads.storage.googleapis.com
